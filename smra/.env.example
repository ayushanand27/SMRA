# Example .env file for SMRA (placeholders — DO NOT commit real secrets)

# LLM provider and keys
LLM_PROVIDER=groq                # groq | ollama | gemini
GROQ_API_KEY=gsk_your_groq_key_here
GROQ_MODEL=mixtral-8x7b-32768    # optional, if using Groq
# If using Ollama or local LLM, set OLLAMA_URL or appropriate vars
# OLLAMA_URL=http://localhost:11434

# Pinecone (RAG)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENV=us-west1-gcp        # Pinecone environment/region (if required)
PINECONE_INDEX=smra-index        # index name used by the project
PINECONE_DIMENSION=384           # must match embedding model (384 for all-MiniLM-L6-v2)
PINECONE_DISABLED=0             # set to 1 to force local RAG fallback (rag_local_store.pkl)

# Embeddings model (used locally when creating vectors)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Tavily (web search)
TAVILY_API_KEY=tvly_your_key_here

# OCR settings (Windows examples)
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
POPPLER_PATH=C:\path\to\poppler\bin
OCR_MAX_PAGES=0                   # 0 = process all pages, >0 = limit for testing
OCR_FORCE=0                       # 1 = force OCR path (skip text-first extraction)

# Database / misc
DATABASE_PATH=smra/data/smra.db
LOG_LEVEL=INFO

# Optional flags
# If you want to force use of local embeddings/Pinecone fallback, set:
# PINECONE_DISABLED=1

# End of example
